@page
@model UrlShortener.Web.Pages.AboutModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About - Linkly Algorithm</title>
    <style>
        body { font-family: sans-serif; background-color: #0B101B; color: #fff; padding: 40px; margin: 0; }
        .container { max-width: 800px; margin: 0 auto; background: rgba(30, 30, 32, 0.4); padding: 30px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.05); }
        h1 { color: #144EE3; }
        textarea { width: 100%; height: 200px; background: #0B101B; border: 1px solid #1E1E20; color: #fff; padding: 15px; border-radius: 10px; resize: vertical; margin-bottom: 20px; }
        button { background-color: #144EE3; color: white; border: none; padding: 10px 20px; font-size: 16px; border-radius: 8px; cursor: pointer; }
        .date { font-size: 12px; opacity: 0.5; margin-bottom: 20px; }
        .admin-box { margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Algorithm Description</h1>
        <div class="date">Last updated: @Model.LastUpdated.ToString("g")</div>
        
        <div style="white-space: pre-line; line-height: 1.6; color: #C9CED6;">
            @Model.AboutContentValue
        </div>

        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
        {
            <div class="admin-box">
                <h3 style="color: #EB568E;">Admin Edit Panel</h3>
                <form method="post">
                    <textarea name="AboutContentValue">@Model.AboutContentValue</textarea>
                    <br />
                    <button type="submit">Update Description</button>
                </form>
            </div>
        }
        
        <div style="margin-top: 50px; text-align: center;">
            <a href="http://localhost:5173" style="color: #144EE3; font-weight: bold; text-decoration: none; border: 1px solid #144EE3; padding: 10px 20px; border-radius: 8px; transition: 0.3s;">
                &larr; Back to Dashboard
            </a>
        </div>
    </div>
</body>
</html>
